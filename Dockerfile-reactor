# ---- Build Stage ----
FROM eclipse-temurin:25-jdk-alpine AS build

WORKDIR /app

# Копируем Gradle wrapper
COPY gradlew .
COPY gradle gradle
RUN chmod +x gradlew

# Копируем корневые конфигурации
COPY build.gradle .
COPY settings.gradle .

# Копируем ВСЕ модули (даже те, что не нужны для сборки Loom)
COPY common common
COPY loom loom
COPY reactor reactor
COPY application-loom application-loom
COPY application-reactor application-reactor

# Собираем только Loom приложение
RUN ./gradlew :application-loom:bootJar -x test

# ---- Run Stage ----
FROM eclipse-temurin:25-jre-alpine

WORKDIR /app

COPY --from=build /app/application-loom/build/libs/*.jar app.jar

RUN addgroup -S appgroup && adduser -S appuser -G appgroup
USER appuser

EXPOSE 8080

ENTRYPOINT ["java", "-jar", "app.jar"]
