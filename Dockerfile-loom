# ---- Build Stage ----
FROM eclipse-temurin:25-jdk-alpine AS build

WORKDIR /app

# Копируем Gradle wrapper
COPY gradlew .
COPY gradle gradle
RUN chmod +x gradlew

# Копируем корневые конфигурации
COPY build.gradle .
COPY settings.gradle .

# Копируем ВСЕ модули (чтобы Gradle не ругался)
COPY common common
COPY loom loom
COPY reactor reactor
COPY application-loom application-loom
COPY application-reactor application-reactor

# Скачиваем зависимости
RUN ./gradlew :application-loom:dependencies --no-daemon || true

# Копируем сгенерированные jOOQ классы
COPY application-loom/build/generated/sources/jooq application-loom/build/generated/sources/jooq

# Собираем Loom приложение
RUN ./gradlew :application-loom:bootJar -x test -x generateJooq --no-daemon

# ---- Run Stage ----
FROM eclipse-temurin:25-jre-alpine

WORKDIR /app

COPY --from=build /app/application-loom/build/libs/*.jar app.jar

RUN addgroup -S appgroup && \
    adduser -S appuser -G appgroup && \
    mkdir -p /app/logs && \
    chown -R appuser:appgroup /app

USER appuser

EXPOSE 8080

ENTRYPOINT ["java", \
    "-XX:+UseZGC", \
    "-Xmx256m", \
    "-Xms128m", \
    "-XX:MaxMetaspaceSize=64m", \
    "-XX:+ExitOnOutOfMemoryError", \
    "-jar", "app.jar"]